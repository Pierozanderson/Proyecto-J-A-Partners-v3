# Copia este archivo como `.env` en local, o define las variables en tu hosting (Vercel, Netlify, etc.)
# antes de `npm run build`. No se muestran en la web.

# URL pública del evento Calendly (embed inline)
# Ejemplo: https://calendly.com/j-a-partners/diagnostico-gratuito
VITE_CALENDLY_URL=

# Opcional: endpoint POST para el formulario de diagnóstico
VITE_FORM_ENDPOINT=